# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def _utc_now_iso() -> str:
    """ISO-8601 UTC timestamp, Python 3.10+ compatible."""
    if hasattr(_dt, "UTC"):  # Python 3.11+
        return _dt.datetime.now(_dt.UTC).isoformat().replace("+00:00", "Z")
    return (
        _dt.datetime.utcnow()
        .replace(tzinfo=_dt.timezone.utc)
        .isoformat()
        .replace("+00:00", "Z")
    )


_PATH_REDACT_RE = re.compile(
    r"(?P<prefix>(?:cat|less|more|head|tail|bat|xxd|hexdump|od)\s+)"
    r"(?P<path>[^\s|;&>]+)"
)


def _redact_for_log(cmd: str) -> str:
    """Strip filesystem paths from secret-file reads before they hit the
    audit log.

    The audit log is intended to be inspectable, but the *path* of a
    blocked credential file is itself sensitive (it leaks where you keep
    your `.aws/credentials`, your home directory layout, etc.).  We
    replace the argument of any read-style command with `<redacted>` and
    keep the basename pattern only when it ends with a known credential
    suffix, so the log still tells you *what kind of file* was blocked
    without leaking *which one*.
    """

    def _sub(match: re.Match[str]) -> str:
        path = match.group("path")
        # Keep just the trailing extension/suffix that triggered the deny
        # rule so the log still says "it was a .env" without saying
        # "it was /home/<user>/projects/foo/.env".
        for suffix in (
            ".env", ".envrc", ".netrc", "credentials.json",
            "id_rsa", "id_ed25519", "id_ecdsa", "id_dsa",
            ".pem", ".p12", ".pfx",
            "/.kube/config", "/.aws/credentials",
            ".npmrc", ".pypirc", ".docker/config.json",
            "secrets.yml", "secrets.yaml", ".git-credentials",
            "hosts.yml", "hosts.yaml",
        ):
            if path.endswith(suffix):
                return f"{match.group('prefix')}<redacted:{suffix}>"
        return f"{match.group('prefix')}<redacted>"

    return _PATH_REDACT_RE.sub(_sub, cmd)


def log_event(kind: str, cmd: str, reason: str = "") -> None:
    """Append one JSON line to the audit log; never raise.

    The ``cmd`` field is path-redacted: if you blocked
    ``cat /home/alice/.aws/credentials`` the log will record
    ``cat <redacted:/.aws/credentials>``.  This prevents the audit trail
    itself from leaking the layout of your filesystem if it gets
    accidentally committed or shared.

    Permissions: ``LOG_DIR`` is forced to 0o700 (owner only) and
    ``LOG_FILE`` is opened with explicit mode 0o600.  This closes the
    secret-literal-in-audit-row leak path identified in the 2026-05-09
    R17 audit (CRITICAL #2): a blocked command line can legitimately
    contain a hard-coded credential, and writing it to a 0o644 file
    would expose it to every other local user.
    """
    try:
        # PCG-CRIT-4 fix (2026-05-09 second-pass R17 audit) — atomic dir mode.
        # Previously we did mkdir(...) then os.chmod(0o700). Under default
        # umask 022 the directory existed at 0o755 for the µs window between
        # those two calls, allowing a co-resident user to swap a symlink in
        # under inotify. mkdir(mode=0o700) bypasses umask and creates the
        # directory with the correct mode in a single syscall.
        LOG_DIR.mkdir(parents=True, exist_ok=True, mode=0o700)
        # Belt-and-braces re-chmod for the case where the directory existed
        # before our process started (mkdir(exist_ok=True) does not chmod).
        try:
            os.chmod(LOG_DIR, 0o700)
        except OSError:
            pass
        # O_NOFOLLOW protects against a symlink swap before we open.
        flags = os.O_WRONLY | os.O_CREAT | os.O_APPEND | getattr(os, "O_NOFOLLOW", 0)
        fd = os.open(str(LOG_FILE), flags, 0o600)
        try:
            os.fchmod(fd, 0o600)
        except OSError:
            pass
        with os.fdopen(fd, "a", encoding="utf-8") as fp:
            fp.write(
                json.dumps(
                    {
                        "ts": _utc_now_iso(),
                        "kind": kind,
                        "cmd": _redact_for_log(cmd),
                        "reason": reason,
                        "version": VERSION,
                    },
                    ensure_ascii=False,
                )
                + "\n"
            )
    except OSError:
        # Logging is best-effort — never fail a hook because of it.
        pass


def emit_block(cmd: str, reason: str) -> None:
    binary = cmd.strip().split(maxsplit=1)[0] if cmd.strip() else "<command>"
    msg = (
        f"[precontext-guard] BLOCKED — {reason}\n"
        "\n"
        "The literal value this command would print could enter the assistant's\n"
        "context window (and from there: chat logs, the model provider's servers,\n"
        "and any attached tooling).  precontext-guard refuses to forward such\n"
        "commands.\n"
        "\n"
        "How to run it safely:\n"
        "  - From your own shell directly: prefix the command with '!' so it runs\n"
        "    locally and its output never reaches the assistant.\n"
        f"        e.g.  ! {binary} ...\n"
        "  - Or capture into an environment variable first, then have the\n"
        "    assistant use that variable by name (without ever reading its\n"
        "    value):\n"
        "        ! read -rs MY_TOKEN; export MY_TOKEN\n"
        "        # in chat afterwards:  invoke as $MY_TOKEN\n"
        "\n"
        "To override (advanced — on your own responsibility):\n"
        "  PCG_OVERRIDE=1 <command>           one-shot bypass\n"
        "  PCG_RULES_FILE=/path/rules.json    custom allow/deny set\n"
        "\n"
        f"precontext-guard {VERSION}\n"
    )
    sys.stderr.write(msg)


def _compile(patterns: Iterable[str]) -> list[re.Pattern[str]]:
    out: list[re.Pattern[str]] = []
    for pat in patterns:
        try:
            out.append(re.compile(pat))
        except re.error:
            # A bad user-supplied pattern should not crash the guard; log and
            # skip it.
            log_event("rule-error", pat, "invalid regex; skipped")
    return out


def load_external_rules(
    path: str,
) -> tuple[list[str], list[tuple[str, str]]]:
    """Load extra allow/deny rules from a JSON file.

    Schema::

        {
          "allow": ["regex", ...],
          "deny":  [{"pattern": "regex", "reason": "..."}, ...]
        }
    """
    try:
        with open(path, encoding="utf-8") as fp:
            doc = json.load(fp)
    except (OSError, json.JSONDecodeError) as exc:
        log_event("rules-error", path, f"could not load: {exc!r}")
        return [], []

    allow = [p for p in doc.get("allow", []) if isinstance(p, str)]
    deny: list[tuple[str, str]] = []
    for entry in doc.get("deny", []):
        if isinstance(entry, dict) and isinstance(entry.get("pattern"), str):
            deny.append(
                (entry["pattern"], str(entry.get("reason", "Custom deny")))
            )
    return allow, deny


def split_segments(cmd: str) -> list[str]:
    """Split a shell command at top-level statement separators.

    Recognised separators (top level only — separators inside single or
    double quotes, or escaped with a backslash, do not split):

    * ``;``  — sequential, status ignored
    * ``&&`` — sequential, run-on-success
    * ``||`` — sequential, run-on-failure
    * ``|``  — pipe (both ends execute)
    * ``\\n`` — newline (multi-line bash blocks)
    * ``&``  — background (the running statement still counts)

    Returns at least one segment for any non-empty input. Empty / pure
    whitespace input yields an empty list.

    This is the core fix for the 2026-05-09 R17 critic finding
    CRITICAL #1: previously a command like
    ``rm -rf /tmp/x; cat .env`` short-circuited on the harmless ``rm``
    prefix matching an allow rule, so the second statement was never
    evaluated. With per-segment scanning each statement must clear the
    deny rules independently.
    """
    out: list[str] = []
    buf: list[str] = []
    in_single = False
    in_double = False
    prev_escape = False
    n = len(cmd)
    i = 0
    while i < n:
        c = cmd[i]
        if prev_escape:
            buf.append(c)
            prev_escape = False
            i += 1
            continue
        if c == "\\" and not in_single:
            buf.append(c)
            prev_escape = True
            i += 1
            continue
        if c == "'" and not in_double:
            in_single = not in_single
            buf.append(c)
            i += 1
            continue
        if c == '"' and not in_single:
            in_double = not in_double
            buf.append(c)
            i += 1
            continue
        if in_single or in_double:
            buf.append(c)
            i += 1
            continue
        # Top-level separators below.
        if c in (";", "\n"):
            seg = "".join(buf).strip()
            if seg:
                out.append(seg)
            buf = []
            i += 1
            continue
        if c == "|" and i + 1 < n and cmd[i + 1] == "|":
            seg = "".join(buf).strip()
            if seg:
                out.append(seg)
            buf = []
            i += 2
            continue
        if c == "&" and i + 1 < n and cmd[i + 1] == "&":
            seg = "".join(buf).strip()
            if seg:
                out.append(seg)
            buf = []
            i += 2
            continue
        if c == "|":
            seg = "".join(buf).strip()
            if seg:
                out.append(seg)
            buf = []
            i += 1
            continue
        if c == "&":
            # Background launcher — the preceding statement still counts.
            seg = "".join(buf).strip()
            if seg:
                out.append(seg)
            buf = []
            i += 1
            continue
        buf.append(c)
        i += 1
    seg = "".join(buf).strip()
    if seg:
        out.append(seg)
    return out


def _decide_segment(
    segment: str,
    allow_pats: list[re.Pattern[str]],
    deny_pats: list[tuple[str, str]],
) -> tuple[str, str]:
    """Evaluate one statement against allow/deny rule sets."""
    for pat in allow_pats:
        if pat.search(segment):
            return "allow", f"matched allow: {pat.pattern}"
    for pat_str, reason in deny_pats:
        try:
            if re.search(pat_str, segment):
                return "block", reason
        except re.error:
            log_event("rule-error", pat_str, "invalid regex; skipped")
            continue
    return "allow", "no rule hit (gray)"


def decide(cmd: str) -> tuple[str, str]:
    """Return (verdict, reason). verdict in {"allow", "block"}.

    Two-pass scan:

    1. **Whole-command deny scan** — catches *structural* patterns where
       the malicious shape spans a separator (e.g.
       ``curl ... | sh``, where neither ``curl`` nor ``sh`` is denied
       in isolation but the pipe-into-shell composition is). Allow rules
       are *not* consulted here; whole-command allow short-circuit was
       the v1 chain-bypass vulnerability that R17 critic CRITICAL #1
       found.
    2. **Per-segment scan** — splits at top-level ``;`` ``&&`` ``||``
       ``|`` ``\\n`` ``&`` and evaluates each statement independently.
       This blocks chains like ``rm -rf /tmp/x; cat .env`` where the
       first segment matches an allow rule. A blocking segment blocks
       the whole call.

    The two scans are complementary: pass 1 sees composition the
    splitter erases, pass 2 sees segments the wholestring scan would
    short-circuit on.
    """
    segments = split_segments(cmd)
    if not segments:
        return "allow", "empty"

    allow_extra: list[str] = []
    deny_extra: list[tuple[str, str]] = []
    rules_path = os.environ.get("PCG_RULES_FILE")
    if rules_path and os.path.isfile(rules_path):
        allow_extra, deny_extra = load_external_rules(rules_path)

    allow_pats = _compile([*allow_extra, *ALLOW_DEFAULT])
    deny_pats: list[tuple[str, str]] = [*deny_extra, *DENY_DEFAULT]

    # Pass 1: whole-string deny scan (structural compositions like
    # `curl ... | sh` that the splitter would atomise).
    for pat_str, reason in deny_pats:
        try:
            if re.search(pat_str, cmd):
                return "block", reason
        except re.error:
            log_event("rule-error", pat_str, "invalid regex; skipped")
            continue

    # Pass 2: per-segment scan (chain-bypass close).
    for segment in segments:
        verdict, reason = _decide_segment(segment, allow_pats, deny_pats)
        if verdict == "block":
            preview = segment if len(segment) <= 80 else segment[:77] + "..."
            return "block", f"segment '{preview}': {reason}"

    return "allow", "no rule hit (gray)"


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main(argv: list[str] | None = None) -> int:
    argv = argv if argv is not None else sys.argv[1:]
    if argv and argv[0] in ("-V", "--version"):
        print(f"precontext-guard {VERSION}")
        return 0
    if argv and argv[0] in ("-h", "--help"):
        print(__doc__)
        return 0

    if sys.stdin.isatty():
        # No JSON piped in — defer.
        return 0

    # CRITICAL #3 fix (2026-05-09 R17 audit) — fail-secure stdin cap.
    #
    # Previously stdin was read without a size limit, so a 1MB junk
    # payload could push the regex engine into pathological backtracking,
    # bubble up an internal error, and ride the documented "fail-open"
    # policy to bypass every deny rule. We now cap at 1 MiB and BLOCK
    # (not approve) on overflow — a real Claude Code PreToolUse payload
    # is well under 64 KiB.
    max_stdin = 1 << 20  # 1 MiB
    raw = sys.stdin.read(max_stdin + 1)
    if len(raw) > max_stdin:
        log_event("block", raw[:200], "stdin > 1 MiB (fail-secure)")
        sys.stderr.write(
            "[precontext-guard] BLOCKED — stdin payload exceeded "
            f"{max_stdin} bytes (fail-secure). This is well above any "
            "real Claude Code PreToolUse payload and is treated as a "
            "regex-exhaustion attack rather than legitimate input.\n"
        )
        return 2
    if not raw.strip():
        return 0

    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        log_event("skip-not-json", raw[:200], "stdin was not valid JSON")
        return 0

    if not isinstance(payload, dict):
        return 0

    if payload.get("tool_name") != "Bash":
        return 0

    tool_input = payload.get("tool_input") or {}
    cmd = tool_input.get("command", "") if isinstance(tool_input, dict) else ""
    if not isinstance(cmd, str) or not cmd.strip():
        return 0

    if os.environ.get("PCG_OVERRIDE") == "1":
        log_event("override", cmd, "PCG_OVERRIDE=1")
        return 0

    verdict, reason = decide(cmd)
    if verdict == "block":
        log_event("block", cmd, reason)
        emit_block(cmd, reason)
        return 2

    log_event("allow", cmd, reason)
    return 0


if __name__ == "__main__":
    sys.exit(main())
