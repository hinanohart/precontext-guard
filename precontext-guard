    r"branch|merge|rebase|tag|show|init|clone|remote|reset|restore|reflog|"
    r"describe|grep|ls-files|cat-file|rev-parse|worktree|cherry-pick|bisect|"
    r"submodule|blame|apply|mv|rm)(\s|$)",
    r"^\s*npm\s+(publish|install|i|run|test|ci|view|outdated|dedup|ls|init|"
    r"version|whoami|ping|search|update|prune|audit|exec|link|unlink)(\s|$)",
