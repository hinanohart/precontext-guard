# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def _utc_now_iso() -> str:
    """ISO-8601 UTC timestamp, Python 3.10+ compatible."""
    if hasattr(_dt, "UTC"):  # Python 3.11+
        return _dt.datetime.now(_dt.UTC).isoformat().replace("+00:00", "Z")
    return (
        _dt.datetime.utcnow()
        .replace(tzinfo=_dt.timezone.utc)
        .isoformat()
        .replace("+00:00", "Z")
    )


_PATH_REDACT_RE = re.compile(
    r"(?P<prefix>(?:cat|less|more|head|tail|bat|xxd|hexdump|od)\s+)"
    r"(?P<path>[^\s|;&>]+)"
)


def _redact_for_log(cmd: str) -> str:
    """Strip filesystem paths from secret-file reads before they hit the
    audit log.

    The audit log is intended to be inspectable, but the *path* of a
    blocked credential file is itself sensitive (it leaks where you keep
    your `.aws/credentials`, your home directory layout, etc.).  We
    replace the argument of any read-style command with `<redacted>` and
    keep the basename pattern only when it ends with a known credential
    suffix, so the log still tells you *what kind of file* was blocked
    without leaking *which one*.
    """

    def _sub(match: re.Match[str]) -> str:
        path = match.group("path")
        # Keep just the trailing extension/suffix that triggered the deny
        # rule so the log still says "it was a .env" without saying
        # "it was /home/<user>/projects/foo/.env".
        for suffix in (
            ".env", ".envrc", ".netrc", "credentials.json",
            "id_rsa", "id_ed25519", "id_ecdsa", "id_dsa",
            ".pem", ".p12", ".pfx",
            "/.kube/config", "/.aws/credentials",
            ".npmrc", ".pypirc", ".docker/config.json",
            "secrets.yml", "secrets.yaml", ".git-credentials",
            "hosts.yml", "hosts.yaml",
        ):
            if path.endswith(suffix):
                return f"{match.group('prefix')}<redacted:{suffix}>"
        return f"{match.group('prefix')}<redacted>"

    return _PATH_REDACT_RE.sub(_sub, cmd)


def log_event(kind: str, cmd: str, reason: str = "") -> None:
    """Append one JSON line to the audit log; never raise.

    The ``cmd`` field is path-redacted: if you blocked
    ``cat /home/alice/.aws/credentials`` the log will record
    ``cat <redacted:/.aws/credentials>``.  This prevents the audit trail
    itself from leaking the layout of your filesystem if it gets
    accidentally committed or shared.
    """
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a", encoding="utf-8") as fp:
            fp.write(
                json.dumps(
                    {
                        "ts": _utc_now_iso(),
                        "kind": kind,
                        "cmd": _redact_for_log(cmd),
                        "reason": reason,
                        "version": VERSION,
                    },
                    ensure_ascii=False,
                )
                + "\n"
            )
    except OSError:
        # Logging is best-effort — never fail a hook because of it.
        pass


def emit_block(cmd: str, reason: str) -> None:
    binary = cmd.strip().split(maxsplit=1)[0] if cmd.strip() else "<command>"
    msg = (
        f"[precontext-guard] BLOCKED — {reason}\n"
        "\n"
        "The literal value this command would print could enter the assistant's\n"
        "context window (and from there: chat logs, the model provider's servers,\n"
        "and any attached tooling).  precontext-guard refuses to forward such\n"
        "commands.\n"
        "\n"
        "How to run it safely:\n"
        "  - From your own shell directly: prefix the command with '!' so it runs\n"
        "    locally and its output never reaches the assistant.\n"
        f"        e.g.  ! {binary} ...\n"
        "  - Or capture into an environment variable first, then have the\n"
        "    assistant use that variable by name (without ever reading its\n"
        "    value):\n"
        "        ! read -rs MY_TOKEN; export MY_TOKEN\n"
        "        # in chat afterwards:  invoke as $MY_TOKEN\n"
        "\n"
        "To override (advanced — on your own responsibility):\n"
        "  PCG_OVERRIDE=1 <command>           one-shot bypass\n"
        "  PCG_RULES_FILE=/path/rules.json    custom allow/deny set\n"
        "\n"
        f"precontext-guard {VERSION}\n"
    )
    sys.stderr.write(msg)


def _compile(patterns: Iterable[str]) -> list[re.Pattern[str]]:
    out: list[re.Pattern[str]] = []
    for pat in patterns:
        try:
            out.append(re.compile(pat))
        except re.error:
            # A bad user-supplied pattern should not crash the guard; log and
            # skip it.
            log_event("rule-error", pat, "invalid regex; skipped")
    return out


def load_external_rules(
    path: str,
) -> tuple[list[str], list[tuple[str, str]]]:
    """Load extra allow/deny rules from a JSON file.

    Schema::

        {
          "allow": ["regex", ...],
          "deny":  [{"pattern": "regex", "reason": "..."}, ...]
        }
    """
    try:
        with open(path, encoding="utf-8") as fp:
            doc = json.load(fp)
    except (OSError, json.JSONDecodeError) as exc:
        log_event("rules-error", path, f"could not load: {exc!r}")
        return [], []

    allow = [p for p in doc.get("allow", []) if isinstance(p, str)]
    deny: list[tuple[str, str]] = []
    for entry in doc.get("deny", []):
        if isinstance(entry, dict) and isinstance(entry.get("pattern"), str):
            deny.append(
                (entry["pattern"], str(entry.get("reason", "Custom deny")))
            )
    return allow, deny


def decide(cmd: str) -> tuple[str, str]:
    """Return (verdict, reason). verdict in {"allow", "block"}."""
    allow_extra: list[str] = []
    deny_extra: list[tuple[str, str]] = []
    rules_path = os.environ.get("PCG_RULES_FILE")
    if rules_path and os.path.isfile(rules_path):
        allow_extra, deny_extra = load_external_rules(rules_path)

    for pat in _compile([*allow_extra, *ALLOW_DEFAULT]):
        if pat.search(cmd):
            return "allow", f"matched allow: {pat.pattern}"

    for pat_str, reason in [*deny_extra, *DENY_DEFAULT]:
        try:
            if re.search(pat_str, cmd):
                return "block", reason
        except re.error:
            log_event("rule-error", pat_str, "invalid regex; skipped")
            continue

    return "allow", "no rule hit (gray)"


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main(argv: list[str] | None = None) -> int:
    argv = argv if argv is not None else sys.argv[1:]
    if argv and argv[0] in ("-V", "--version"):
        print(f"precontext-guard {VERSION}")
        return 0
    if argv and argv[0] in ("-h", "--help"):
        print(__doc__)
        return 0

    if sys.stdin.isatty():
        # No JSON piped in — defer.
        return 0
    raw = sys.stdin.read()
    if not raw.strip():
        return 0

    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        log_event("skip-not-json", raw[:200], "stdin was not valid JSON")
        return 0

    if not isinstance(payload, dict):
        return 0

    if payload.get("tool_name") != "Bash":
        return 0

    tool_input = payload.get("tool_input") or {}
    cmd = tool_input.get("command", "") if isinstance(tool_input, dict) else ""
    if not isinstance(cmd, str) or not cmd.strip():
        return 0

    if os.environ.get("PCG_OVERRIDE") == "1":
        log_event("override", cmd, "PCG_OVERRIDE=1")
        return 0

    verdict, reason = decide(cmd)
    if verdict == "block":
        log_event("block", cmd, reason)
        emit_block(cmd, reason)
        return 2

    log_event("allow", cmd, reason)
    return 0


if __name__ == "__main__":
    sys.exit(main())
