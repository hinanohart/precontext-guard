    r"workspace|exec|dlx)(\s|$)",
    r"^\s*npx\s+\S",
    r"^\s*pip3?\s+(install|list|show|freeze|uninstall|search|check|wheel|"
    r"download|index)(\s|$)",
    r"^\s*pipx\s+(install|run|list|upgrade|uninstall|inject|reinstall|"
    r"runpip)(\s|$)",
    r"^\s*cargo\s+(build|run|test|fmt|check|clippy|publish|install|new|init|"
    r"update|doc|bench|tree|search)(\s|$)",
    r"^\s*go\s+(build|run|test|fmt|vet|mod|install|get|generate|tool|doc|"
