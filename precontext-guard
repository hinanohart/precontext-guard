#!/usr/bin/env python3
"""precontext-guard — block CLI commands that would leak secrets into the
assistant's context window before they ever execute.

This is a Claude Code PreToolUse hook.  Anthropic's runtime feeds the hook a
JSON document on stdin describing the impending tool call; if we exit with
status 2 the call is blocked and our stderr message is shown to the model.

The guard is *pre-context*: it stops commands like ``gh auth token`` or
``cat .env`` *before* they run, so the literal secret never lands in the
chat transcript, the model's request payload, or the provider's logs.

License: Apache-2.0
Project: https://github.com/<owner>/precontext-guard
"""

from __future__ import annotations

import datetime as _dt
import json
import os
import re
import sys
from pathlib import Path
from typing import Iterable

VERSION = "0.1.0"

# ---------------------------------------------------------------------------
# Locations
# ---------------------------------------------------------------------------

_DEFAULT_STATE = Path(
    os.environ.get("XDG_STATE_HOME") or (Path.home() / ".local" / "state")
)
LOG_DIR = Path(os.environ.get("PCG_LOG_DIR", _DEFAULT_STATE / "precontext-guard"))
LOG_FILE = LOG_DIR / "audit.jsonl"

# ---------------------------------------------------------------------------
# Default allow list — first hit wins, evaluated before deny patterns.
#
# These are the safe shapes we expect to see in agentic workflows.  They are
# deliberately narrow: ``gh auth status`` is fine because it only prints
# whether you are logged in, but ``gh auth token`` (which prints the token
# itself) is *not* listed here and falls through to the deny stage.
# ---------------------------------------------------------------------------

ALLOW_DEFAULT: list[str] = [
    r"^\s*gh\s+(pr|issue|repo|run|api|workflow|release|browse|search|gist|"
    r"cache|attestation|extension|label|project|status|codespace|ruleset)"
    r"(\s|$)",
    r"^\s*gh\s+auth\s+(status|logout|switch|setup-git|refresh)(\s|$)",
    r"^\s*git\s+(push|pull|fetch|status|log|diff|commit|add|stash|checkout|"
    r"branch|merge|rebase|tag|show|init|clone|remote|reset|restore|reflog|"
    r"describe|grep|ls-files|cat-file|rev-parse|worktree|cherry-pick|bisect|"
    r"submodule|blame|apply|mv|rm)(\s|$)",
